{
  "name": "zotero-metadata-hunter",
  "version": "0.3.0",
  "description": "A Zotero plugin to find and add missing DOI numbers and abstracts to references",
  "config": {
    "addonName": "Metadata Hunter",
    "addonID": "metadatahunter@federicotorrielli.github.io",
    "addonRef": "metadatahunter",
    "addonInstance": "MetadataHunter",
    "prefsPrefix": "extensions.zotero.metadatahunter"
  },
  "main": "src/index.ts",
  "scripts": {
    "build": "tsc --noEmit && node scripts/build.mjs production",
    "start": "node scripts/start.mjs",
    "stop": "node scripts/stop.mjs",
    "lint": "prettier --write . && eslint . --ext .ts --fix",
    "test": "echo \"Error: no test specified\" && exit 1",
    "release": "release-it",
    "update-deps": "pnpm update --save"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/federicotorrielli/zotero-metadata-hunter.git"
  },
  "author": {
    "name": "Federico Torrielli",
    "email": "evilscript@protonmail.com"
  },
  "bugs": {
    "url": "https://github.com/federicotorrielli/zotero-metadata-hunter/issues"
  },
  "homepage": "https://github.com/federicotorrielli/zotero-metadata-hunter#readme",
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "chokidar": "^5.0.0",
    "compressing": "^2.1.1",
    "esbuild": "^0.27.7",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "prettier": "^3.8.3",
    "release-it": "^19.2.4",
    "replace-in-file": "^8.4.0",
    "typescript": "^6.0.3",
    "zotero-types": "^4.1.2"
  }
}
